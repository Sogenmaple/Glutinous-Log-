/* ============================================
   贪吃蛇 - 黑白漫画风格
   ============================================ */

/* ========== 页面基础 ========== */
.manga-snake-page {
  min-height: 100vh;
  width: 100%;
  background: #f8f8f8;
  background-image: 
    radial-gradient(#cccccc 1px, transparent 1px),
    radial-gradient(#cccccc 1px, transparent 1px);
  background-size: 24px 24px;
  background-position: 0 0, 12px 12px;
  font-family: 'Georgia', 'Times New Roman', serif;
  padding-top: 80px;
  position: relative;
}

/* 背景装饰 */
.manga-halftone {
  position: fixed;
  inset: 0;
  background-image: 
    radial-gradient(#000000 1px, transparent 1px),
    radial-gradient(#000000 1px, transparent 1px);
  background-size: 6px 6px, 12px 12px;
  background-position: 0 0, 3px 3px;
  opacity: 0.12;
  pointer-events: none;
  z-index: 0;
}

.manga-concentration {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 60vw;
  height: 60vw;
  border-radius: 50%;
  background: repeating-radial-gradient(
    circle at center,
    transparent 0,
    transparent 20px,
    rgba(0, 0, 0, 0.03) 20px,
    rgba(0, 0, 0, 0.03) 40px
  );
  pointer-events: none;
  z-index: 0;
}

/* ========== 主容器 ========== */
.manga-container {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 1400px;
  margin: 0 auto;
  padding: 2rem 3rem;
  box-sizing: border-box;
}

/* ========== 报头 ========== */
.manga-masthead {
  margin-bottom: 2.5rem;
  padding: 2rem;
  background: #ffffff;
  border: 5px solid #1a1a1a;
  box-shadow: 10px 10px 0 #1a1a1a, 16px 16px 0 #444444;
  position: relative;
}

.manga-masthead-top {
  display: flex;
  justify-content: space-between;
  margin-bottom: 1.5rem;
  padding-bottom: 1rem;
  border-bottom: 3px solid #1a1a1a;
}

.manga-issue {
  font-family: 'Courier New', monospace;
  font-size: 0.75rem;
  font-weight: 700;
  color: #666666;
  letter-spacing: 0.15em;
}

.manga-date {
  font-family: 'Georgia', serif;
  font-size: 0.85rem;
  font-weight: 700;
  color: #1a1a1a;
}

.manga-main-title {
  text-align: center;
  margin-bottom: 1.5rem;
}

.manga-title-cn {
  font-family: 'Georgia', serif;
  font-size: clamp(2.5rem, 5vw, 4rem);
  font-weight: 900;
  color: #1a1a1a;
  margin: 0;
  letter-spacing: 0.2em;
  text-transform: uppercase;
}

.manga-title-en {
  display: block;
  font-family: 'Courier New', monospace;
  font-size: clamp(0.9rem, 1.5vw, 1.2rem);
  font-weight: 700;
  color: #666666;
  letter-spacing: 0.4em;
  margin-top: 0.5rem;
  text-transform: uppercase;
}

.manga-tagline {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 1rem;
  flex-wrap: wrap;
}

.manga-tagline span {
  font-family: 'Courier New', monospace;
  font-size: 0.85rem;
  font-weight: 900;
  color: #ffffff;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  background: #1a1a1a;
  padding: 0.5rem 1rem;
  border: 3px solid #ffffff;
  box-shadow: 4px 4px 0 #444444;
}

.manga-sep {
  color: #1a1a1a;
  font-size: 1.2rem;
  font-weight: 900;
}

/* ========== 游戏主区域 ========== */
.manga-snake-main {
  display: flex;
  justify-content: center;
  align-items: flex-start;
  gap: 2rem;
  margin-bottom: 2rem;
  flex-wrap: nowrap;
}

.manga-snake-main > aside:first-child {
  flex: 0 0 240px;
}

.manga-snake-main > .manga-game-section {
  flex: 0 0 auto;
}

.manga-snake-main > aside:last-child {
  flex: 0 0 320px;
}

/* ========== 侧边面板 ========== */
.manga-side-panel {
  background: #ffffff;
  border: 4px solid #1a1a1a;
  box-shadow: 8px 8px 0 #1a1a1a;
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100%;
}

.manga-panel-header {
  padding: 1rem;
  background: #1a1a1a;
  color: #ffffff;
  font-family: 'Courier New', monospace;
  font-size: 0.85rem;
  font-weight: 900;
  letter-spacing: 0.15em;
  text-align: center;
  border-bottom: 3px solid #1a1a1a;
}

.manga-panel-content {
  padding: 1rem;
  flex: 1;
}

/* 统计行 */
.manga-stat-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.75rem;
  margin-bottom: 0.5rem;
  background: #f0f0f0;
  border: 2px solid #1a1a1a;
  box-shadow: 3px 3px 0 #444444;
}

.manga-stat-label {
  font-family: 'Courier New', monospace;
  font-size: 0.75rem;
  font-weight: 700;
  color: #666666;
  letter-spacing: 0.1em;
}

.manga-stat-value {
  font-family: 'Courier New', monospace;
  font-size: 1.1rem;
  font-weight: 900;
  color: #1a1a1a;
}

.manga-stat-value.highlight {
  color: #1a1a1a;
}

/* 状态徽章 */
.manga-status-badge-container {
  padding: 1rem;
  text-align: center;
  border-top: 3px solid #1a1a1a;
}

.manga-status-badge {
  display: inline-block;
  padding: 0.5rem 1rem;
  font-family: 'Courier New', monospace;
  font-size: 0.8rem;
  font-weight: 900;
  letter-spacing: 0.15em;
  border: 3px solid #1a1a1a;
  text-transform: uppercase;
}

.manga-status-badge.ready {
  background: #f0f0f0;
  color: #1a1a1a;
  box-shadow: 4px 4px 0 #444444;
}

.manga-status-badge.active {
  background: #1a1a1a;
  color: #ffffff;
  box-shadow: 4px 4px 0 #666666;
}

.manga-status-badge.danger {
  background: #ffffff;
  color: #1a1a1a;
  border-color: #1a1a1a;
  box-shadow: 4px 4px 0 #444444;
}

/* 信息行 */
.manga-info-row {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 0;
  font-size: 0.8rem;
}

.manga-info-bullet {
  width: 8px;
  height: 8px;
  background: #1a1a1a;
  flex-shrink: 0;
}

.manga-info-desc {
  color: #333333;
  line-height: 1.5;
}

/* ========== 游戏区域 ========== */
.manga-game-section {
  display: flex;
  align-items: center;
  justify-content: center;
}

.manga-game-container {
  position: relative;
  width: 620px;
  height: 620px;
  background: #ffffff;
  border: 5px solid #1a1a1a;
  box-shadow: 12px 12px 0 #1a1a1a, 20px 20px 0 #444444;
}

.manga-game-board {
  position: relative;
  width: 100%;
  height: 100%;
}

.manga-bg-grid {
  position: absolute;
  inset: 0;
  background-image: 
    linear-gradient(rgba(0, 0, 0, 0.08) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 0, 0, 0.08) 1px, transparent 1px);
  background-size: 20px 20px;
  pointer-events: none;
}

/* 蛇身 */
.manga-snake-segment {
  position: absolute;
  background: #1a1a1a;
  border: 2px solid #ffffff;
  box-shadow: 3px 3px 0 #444444;
  transition: all 0.05s linear;
}

.manga-snake-segment.head {
  background: #1a1a1a;
  border: 3px solid #ffffff;
  box-shadow: 4px 4px 0 #666666;
  z-index: 2;
}

.manga-snake-segment.head::before,
.manga-snake-segment.head::after {
  content: '';
  position: absolute;
  width: 5px;
  height: 5px;
  background: #ffffff;
  border-radius: 50%;
  top: 4px;
}

.manga-snake-segment.head::before { left: 4px; }
.manga-snake-segment.head::after { right: 4px; }

/* 食物 */
.manga-food {
  position: absolute;
  background: #ffffff;
  border: 3px solid #1a1a1a;
  border-radius: 50%;
  box-shadow: 4px 4px 0 #444444;
  animation: mangaFoodPulse 1s ease-in-out infinite;
  z-index: 1;
}

@keyframes mangaFoodPulse {
  0%, 100% { 
    transform: scale(1);
    box-shadow: 4px 4px 0 #444444;
  }
  50% { 
    transform: scale(1.15);
    box-shadow: 6px 6px 0 #666666;
  }
}

/* 覆盖层 */
.manga-overlay {
  position: absolute;
  inset: 0;
  background: rgba(248, 248, 248, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.manga-overlay-content {
  text-align: center;
  padding: 2rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
}

.manga-icon-box {
  width: 80px;
  height: 80px;
  background: #1a1a1a;
  border: 4px solid #1a1a1a;
  box-shadow: 6px 6px 0 #444444;
  display: flex;
  align-items: center;
  justify-content: center;
}

.manga-overlay-title {
  font-family: 'Georgia', serif;
  font-size: 2rem;
  font-weight: 900;
  color: #1a1a1a;
  margin: 0;
  letter-spacing: 0.15em;
}

.manga-overlay-subtitle {
  font-family: 'Courier New', monospace;
  font-size: 0.8rem;
  font-weight: 700;
  color: #666666;
  letter-spacing: 0.2em;
  text-transform: uppercase;
}

.manga-start-btn {
  font-size: 1rem;
  font-weight: 900;
  color: #ffffff;
  background: #1a1a1a;
  border: 4px solid #1a1a1a;
  padding: 0.8rem 2.5rem;
  cursor: pointer;
  margin-top: 0.5rem;
  transition: all 0.2s;
  box-shadow: 6px 6px 0 #444444;
  letter-spacing: 0.15em;
  font-family: 'Courier New', monospace;
  text-transform: uppercase;
}

.manga-start-btn:hover {
  transform: translate(-3px, -3px);
  box-shadow: 9px 9px 0 #666666;
}

.manga-button-group {
  display: flex;
  gap: 1rem;
  margin-top: 0.5rem;
  justify-content: center;
}

.manga-controls-hint {
  font-size: 0.75rem;
  color: #666666;
  margin-top: 0.5rem;
  letter-spacing: 0.05em;
}

.manga-key-badge {
  display: inline-block;
  padding: 0.2rem 0.6rem;
  background: #1a1a1a;
  color: #ffffff;
  border: 2px solid #1a1a1a;
  margin: 0 0.3rem;
  font-size: 0.7rem;
  font-weight: 700;
  font-family: 'Courier New', monospace;
}

/* 游戏结束界面 */
.manga-score-board {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  width: 100%;
  padding: 1rem;
  background: #f0f0f0;
  border: 3px solid #1a1a1a;
  box-shadow: 5px 5px 0 #444444;
}

.manga-score-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.5rem;
}

.manga-score-label {
  font-family: 'Courier New', monospace;
  font-size: 0.75rem;
  font-weight: 700;
  color: #666666;
  letter-spacing: 0.1em;
}

.manga-score-value {
  font-family: 'Courier New', monospace;
  font-size: 1.2rem;
  font-weight: 900;
  color: #1a1a1a;
}

.manga-score-value.highlight {
  color: #1a1a1a;
}

.manga-new-record {
  padding: 0.75rem 1.5rem;
  background: #1a1a1a;
  color: #ffffff;
  font-family: 'Courier New', monospace;
  font-size: 0.85rem;
  font-weight: 900;
  letter-spacing: 0.15em;
  border: 3px solid #1a1a1a;
  box-shadow: 4px 4px 0 #666666;
}

/* ========== 底部 ========== */
.manga-footer {
  margin-top: 2rem;
  padding: 2rem;
  background: #ffffff;
  border: 5px solid #1a1a1a;
  box-shadow: 10px 10px 0 #1a1a1a, 16px 16px 0 #444444;
}

.manga-footer-content {
  text-align: center;
}

.manga-footer-line {
  font-family: 'Courier New', monospace;
  font-size: 0.75rem;
  font-weight: 700;
  color: #666666;
  letter-spacing: 0.1em;
  margin-bottom: 0.5rem;
}

.manga-icp a {
  display: inline-block;
  font-family: 'Georgia', serif;
  font-size: 0.75rem;
  color: #1a1a1a;
  text-decoration: none;
  padding: 0.4rem 0.8rem;
  background: #f0f0f0;
  border: 2px solid #1a1a1a;
  transition: all 0.2s;
}

.manga-icp a:hover {
  background: #1a1a1a;
  color: #ffffff;
}

/* ========== 响应式 ========== */
@media (max-width: 1200px) {
  .manga-snake-main {
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  
  .manga-side-panel {
    flex-direction: row;
    flex-wrap: wrap;
  }
  
  .manga-panel-content {
    flex: 1;
  }
  
  .manga-game-container {
    width: 100%;
    max-width: 500px;
    height: auto;
    aspect-ratio: 1 / 1;
  }
}

@media (max-width: 768px) {
  .manga-container {
    padding: 1rem;
  }
  
  .manga-masthead {
    padding: 1.5rem;
  }
  
  .manga-title-cn {
    font-size: 2rem;
  }
  
  .manga-game-container {
    width: 100% !important;
    height: auto !important;
    aspect-ratio: 1 / 1;
  }
  
  .manga-side-panel {
    flex-direction: column;
  }
}
